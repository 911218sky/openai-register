# 郵箱域名
MAIL_DOMAIN=your.domain.com

# Gmail IMAP 配置
# 啟用 Google 帳戶的兩步驟驗證並生成應用程式密碼: https://myaccount.google.com/apppasswords
IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Token 輸出目錄
TOKEN_OUTPUT_DIR=./tokens

# SSL 驗證（0=關閉，1=開啟）
OPENAI_SSL_VERIFY=1

# 跳過網路檢查（0=不跳過，1=跳過）
SKIP_NET_CHECK=0
